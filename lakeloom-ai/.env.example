# ── Databricks connection ──────────────────────────────────────────────────────
DATABRICKS_HOST=https://fevm-hls-fde.cloud.databricks.com
DATABRICKS_APP_PORT=8000
DATABRICKS_APP_NAME=lakeloom-ai-dev

# ── SQL Warehouse (analytics plugin) ──────────────────────────────────────────
DATABRICKS_WAREHOUSE_ID=64d286e6be17d837

# ── UC Volumes (files plugin — auto-discovers all DATABRICKS_VOLUME_* vars) ───
# Each env var maps to a volume key in the Files UI (e.g. "session-audio").
# Values are the full volume path: /Volumes/<catalog>/<schema>/<volume_name>
DATABRICKS_VOLUME_SESSION_AUDIO=/Volumes/hls_fde_dev/dev_matthew_giglia_lakeloom/session_audio
DATABRICKS_VOLUME_SCREENSHOTS=/Volumes/hls_fde_dev/dev_matthew_giglia_lakeloom/screenshots
DATABRICKS_VOLUME_DOCUMENTS=/Volumes/hls_fde_dev/dev_matthew_giglia_lakeloom/documents

# ── Lakebase (postgres plugin) ────────────────────────────────────────────────
# For local dev: resolve these via `databricks postgres list-endpoints`
# At deploy time: the platform injects these automatically from app.yaml valueFrom.
PGHOST=your_postgres_host
PGDATABASE=your_postgres_databaseName
PGPORT=5432
PGSSLMODE=require
LAKEBASE_ENDPOINT=projects/dev-matthew-giglia-lakeloom/branches/production/endpoints/<endpoint-id>
