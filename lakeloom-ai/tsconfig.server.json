{
  "extends": "./tsconfig.shared.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022"],
    "noEmit": true,
    "rootDir": "./"
  },
  "include": ["server/**/*", "shared/**/*", "config/**/*"],
  "exclude": ["node_modules", "dist", "client"]
}
