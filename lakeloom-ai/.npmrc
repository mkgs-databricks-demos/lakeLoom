# Required by @databricks/zerobus-ingest-sdk: it declares an optional peer
# dependency on apache-arrow@^56.0.0, which doesn't exist in any registry
# (apache-arrow's latest is v21.1.0 as of 2026-05-12). Without legacy-peer-deps,
# `npm install` fails with ETARGET even though the peer is marked optional.
# Flag this back to the Zerobus team for an upstream fix; remove this file
# once their package.json points at a real apache-arrow version.
legacy-peer-deps=true
