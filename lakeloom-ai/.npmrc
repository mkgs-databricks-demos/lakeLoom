# @databricks/zerobus-ingest-sdk declares peerDependencies.apache-arrow@^56.0.0
# which doesn't exist (latest is ~21.x). The override in package.json resolves
# this to ^21.1.0, but legacy-peer-deps remains as belt-and-suspenders in case
# other transitive peer conflicts arise from native binary packages.
# Remove once the ZeroBus team publishes a fixed package.json.
legacy-peer-deps=true
